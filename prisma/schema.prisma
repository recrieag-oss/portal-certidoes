generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id
  email            String    @unique
  passwordHash     String
  nome             String    @default("")
  cpf              String    @default("")
  whatsapp         String    @default("")
  createdAt        DateTime  @default(now())
  resetToken       String?
  resetTokenExpiry DateTime?
  orders           Order[]
}

model Order {
  id            String   @id
  userId        String
  tipo          String
  status        String   @default("recebido")
  statusHistory Json     @default("[]")
  formData      Json
  pedidoResumo  Json
  pdfPath       String?
  paymentId     String?
  paymentStatus String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

// Session userId is a plain string — no FK so admin sessions ("admin") work without a User record
model Session {
  id        String   @id
  userId    String
  role      String   @default("client")
  expiresAt DateTime
}
